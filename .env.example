# publish.py settings & secrets.  Copy to .env  (── .env is gitignored ──).
# CLI flags override these.

# Path to the central monitoring repo (has config.json + monitoring.db).
CENTRAL_DIR=../aidas-ai-monitoring

# Where to write the snapshot the static site serves.
OUT=data/dashboard.json

# 1 = mask account emails in the published snapshot (use for PUBLIC repos).
REDACT=0

# --- optional: non-interactive `git push` for the auto-publish cron ---
# Prefer an SSH deploy key (then leave these blank). Otherwise use a
# fine-grained Personal Access Token scoped to THIS repo with contents:write.
GITHUB_TOKEN=
GIT_REMOTE=https://github.com/USER/aidas-ai-monitoring-dashboard.git
